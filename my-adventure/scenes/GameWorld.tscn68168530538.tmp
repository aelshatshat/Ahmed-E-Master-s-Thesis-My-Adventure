[sub_resource type="RectangleShape2D" id="RectangleShape2D_13lyd"]

[sub_resource type="GDScript" id="GDScript_yms0u"]
script/source = "class_name ExplosionComboSpell
extends ComboSpell

@export var explosion_scene: PackedScene

@export var step_explosion_pattern: Array[String] = [
	\"single\",
	\"forward\",
	\"upward\",
	\"flurry\"
]

@export var step_explosion_count: Array[int] = [1, 5, 4, 8]

func cast(caster: Node) -> void:
	print(\"%s triggered as combo spell!\" % name)
	
	cast_combo_step(caster.get_parent().combo_step, caster.get_parent(), 1)

func cast_combo_step(step: int, caster: Node2D, facing_dir: int):
	if step < 1 or step > step_explosion_pattern.size():
		push_warning(\"Invalid combo step: %d\" % step)
		return
	
	var pattern_type := step_explosion_pattern[step - 1]
	var count := step_explosion_count[step - 1]
	var start_pos := caster.global_position
	print(\"FUCK YOU\");
	
	match pattern_type:
		\"single\":
			_spawn_single(start_pos + Vector2(60 * facing_dir, -10))
		\"forward\":
			await _spawn_chain_forward(start_pos + Vector2(40 * facing_dir, -10), facing_dir, count, caster)
		\"upward\":
			await _spawn_chain_upward(start_pos + Vector2(0, -20), count, caster)
		\"flurry\":
			await _spawn_flurry_around(start_pos, count, caster)

# ----- Explosion patterns -----

func _spawn_single(position: Vector2):
	_spawn_explosion(position)

func _spawn_chain_forward(start_pos: Vector2, direction: int, count: int, caster: Node, delay: float = 0.1):
	for i in range(count):
		await caster.get_tree().create_timer(delay * i).timeout
		var offset = Vector2(60 * i * direction, 0)
		_spawn_explosion(start_pos + offset)

func _spawn_chain_upward(start_pos: Vector2, count: int, caster: Node, delay: float = 0.1):
	for i in range(count):
		await caster.get_tree().create_timer(delay * i).timeout
		var offset = Vector2(0, -50 * i)
		_spawn_explosion(start_pos + offset)

func _spawn_flurry_around(center: Vector2, count: int, caster: Node, radius: float = 80.0, delay: float = 0.07):
	for i in range(count):
		await caster.get_tree().create_timer(delay * i).timeout
		var angle = randf() * TAU
		var offset = Vector2(radius * cos(angle), radius * sin(angle))
		_spawn_explosion(center + offset)

func _spawn_explosion(position: Vector2):
	if not explosion_scene:
		push_warning(\"No explosion_scene set!\")
		return
	if world_parent:
		var explosion = explosion_scene.instantiate()
		explosion.global_position = position
		world_parent.add_child(explosion)

var world_parent: Node = null
func set_world_parent(parent: Node):
	world_parent = parent
"

